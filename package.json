{
  "name": "elysia-ssr",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run start:watch & bun run css:watch",
    "build": "bun build --minify --target bun --outdir build src/index.ts",
    "start": "bun run src/index.ts",
    "start:watch": "bun run --watch src/index.ts",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "prisma generate && bun test",
    "db:migrate": "prisma migrate dev && prisma generate",
    "db:reset": "prisma migrate reset --force && prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push && prisma generate",
    "lint": "bunx biome lint ./src",
    "format": "bunx biome format --write ./src",
    "css:build": "bunx @tailwindcss/cli -i ./src/styles/main.css -o ./public/styles.css",
    "css:watch": "bunx @tailwindcss/cli -i ./src/styles/main.css -o ./public/styles.css --watch"
  },
  "bun-create": {
    "start": "bun db:push && bun dev",
    "postinstall": "src/tasks/postinstall.js"
  },
  "dependencies": {
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/static": "^1.4.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/cli": "^4.1.18",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "elysia": "latest",
    "eta": "^3.5.0",
    "pino": "^9.14.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.3.14",
    "bun-types": "latest",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "typescript": "^5.9.3"
  }
}
